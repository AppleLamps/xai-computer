# Copy this file to .env and fill in your values.
# Only XAI_API_KEY is required. Everything else has sensible defaults.

# ── API ──────────────────────────────────────────────────────
# Required. Get your key at https://console.x.ai/
XAI_API_KEY=

# ── Model ────────────────────────────────────────────────────
# Default model for chat completions.
# Presets available at runtime with /model:
#   fast    -> grok-4-1-fast-reasoning   (lower cost)
#   quality -> grok-4.20-0309-reasoning  (max quality)
# Grok 4 models are required for structured output features
# (shell explanations, execution summaries). Other models work
# but fall back to plain-text rendering.
# XAI_MODEL=grok-4-1-fast-reasoning

# Optional: auto-switch to this model for coding tasks
# (code generation, file writing, website building).
# Leave blank to always use XAI_MODEL.
# XAI_CODING_MODEL=grok-code-fast-1

# ── File Safety ──────────────────────────────────────────────
# Semicolon-separated absolute paths where file operations are allowed.
# Defaults to Desktop, Documents, and Downloads under your user profile.
# XAI_ASSISTANT_ALLOWED_ROOTS=C:\Users\you\Desktop;C:\Users\you\Documents

# Override auto-detected desktop path (useful for OneDrive redirection).
# XAI_ASSISTANT_DESKTOP=C:\Users\you\OneDrive\Desktop

# ── Behavior ─────────────────────────────────────────────────
# Enable xAI built-in web search (may not be supported on all models).
# XAI_ENABLE_WEB_SEARCH=0

# Max tool-call round-trips per user turn (1-50).
# XAI_MAX_TOOL_LOOPS=12

# ── Shell Execution ──────────────────────────────────────────
# Additional commands to add to the SAFE tier (comma-separated).
# These bypass the "risky" warning but still require confirmation.
# Use with caution — each entry expands what the model can request.
# XAI_SHELL_ALLOWLIST_EXTRA=cargo build,dotnet --version
